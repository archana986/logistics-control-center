# Backend API URL
# For local development, this should point to your local backend
# In Databricks Apps, this will be automatically configured
VITE_BACKEND_URL=http://localhost:8001/api

# Databricks Model Endpoint
# The name of the model serving endpoint to use
DATABRICKS_MODEL_ENDPOINT=databricks-llama-4-maverick

# Databricks CLI Profile (for local development only)
# The name of the CLI profile to use when running locally
# Run 'databricks auth profiles' to see available profiles
# Use a profile that is marked as "YES" (valid)
DATABRICKS_CLI_PROFILE=dev

# SQL Warehouse ID
# Required for querying Delta tables via SQL Statement Execution API
DATABRICKS_SQL_WAREHOUSE_ID=

# Unity Catalog Configuration
DATABRICKS_CATALOG=demos
DATABRICKS_SCHEMA=logistics_control_center

# Agent Bricks Configuration
# Genie Space ID (get from Genie space URL after creation)
DATABRICKS_GENIE_SPACE_ID=

# Knowledge Assistant Endpoint Name (get from Agent Bricks page)
DATABRICKS_KA_ENDPOINT=

# Multi-Agent Supervisor Endpoint Name (get from Agent Bricks page)
DATABRICKS_SUPERVISOR_ENDPOINT=

# Backend Port (for backend service)
PORT=8001

# Node Environment
NODE_ENV=development

# Stream Simulator Configuration (optional)
SIMULATOR_INTERVAL_SECONDS=30
