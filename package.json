{
  "name": "demo-logistics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "cd .. && uvicorn demo-logistics.backend.main:app --reload --host 0.0.0.0 --port 8001",
    "dev:all": "npm run dev:backend & npm run dev",
    "build": "tsc -b && vite build",
    "start": "vite preview --host 0.0.0.0 --port 8000",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test -c e2e/playwright.config.ts --headed",
    "test:e2e:ui": "playwright test -c e2e/playwright.config.ts --ui"
  },
  "dependencies": {
    "@deck.gl/layers": "^9.2.2",
    "@deck.gl/react": "^9.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deck.gl": "^9.2.2",
    "lucide-react": "^0.546.0",
    "maplibre-gl": "^5.9.0",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-map-gl": "^8.1.0",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.3.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.16",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "vaul": "^1.1.2",
    "vite": "^7.1.7",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@eslint/js": "^9.36.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "typescript-eslint": "^8.45.0"
  }
}
